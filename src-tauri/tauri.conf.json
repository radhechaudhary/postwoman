{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "postwoman",
  "version": "0.1.0",
  "identifier": "com.radhechaudhary.postwoman",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Postwoman",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "rpm",
      "msi",
      "nsis",
      "deb"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}